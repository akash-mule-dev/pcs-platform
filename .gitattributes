# Normalize line endings to LF in the repo to kill the phantom "297 files changed"
# diff (working tree was CRLF while git stored LF). After committing this file, run:
#     git add --renormalize .
#     git commit -m "Normalize line endings to LF"
* text=auto eol=lf

# Binary assets — never normalize these
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.glb  binary
*.gltf binary
*.fbx  binary
*.stl  binary
*.zip  binary
*.db   binary
*.keystore binary
*.jar  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
