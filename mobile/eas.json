{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "dev": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://backend-git-dev-akash-mule-devs-projects.vercel.app/api",
        "EXPO_PUBLIC_WEB_URL": "https://frontend-git-dev-akash-mule-devs-projects.vercel.app"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      }
    },
    "quest": {
      "distribution": "internal",
      "env": {
        "XR_MODE": "VR"
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}
