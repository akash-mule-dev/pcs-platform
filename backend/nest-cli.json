{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "cad-conversion/scripts/*.mjs",
        "outDir": "dist",
        "watchAssets": true
      }
    ]
  },
  "projects": {
    "vercel": {
      "type": "application",
      "root": "",
      "sourceRoot": "src",
      "entryFile": "serverless",
      "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true,
        "webpackConfigPath": "webpack.config.js"
      }
    }
  }
}
