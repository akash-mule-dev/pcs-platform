# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=pcs_user
DB_PASSWORD=pcs_password
DB_NAME=pcs_db
DB_SSL=false
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  (overrides individual DB_ vars)

# JWT — REQUIRED in production (app will refuse to start without it)
JWT_SECRET=your-super-secret-jwt-key-change-this

# App
PORT=3000
NODE_ENV=production

# CORS (comma-separated origins)
CORS_ORIGIN=https://your-frontend-domain.com

# Storage (local | s3 | azure)
STORAGE_TYPE=local
# S3_BUCKET=your-bucket
# S3_REGION=ap-south-1
# S3_PREFIX=uploads/
# AZURE_STORAGE_CONNECTION_STRING=...
# AZURE_CONTAINER_NAME=...

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
