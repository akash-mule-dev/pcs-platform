# Database
# Shared team DEV database (Neon branch pcs-dev-db — isolated from prod, safe for local dev).
# Copy this file to .env and uncomment the two lines below to use it:
# DATABASE_URL=postgresql://neondb_owner:npg_Lvc4gdNxMV5w@ep-red-hall-aqifonr3-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require
# DB_SSL=true
DB_HOST=postgres
DB_PORT=5432
DB_USER=pcs_user
DB_PASSWORD=pcs_password
DB_NAME=pcs_db
DB_SSL=false
# Schema auto-sync: ON in non-prod by default, always OFF in production.
# Override (non-prod only): DB_SYNCHRONIZE=true|false. Use migrations in production.
# DB_SYNCHRONIZE=false
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  (overrides individual DB_ vars)

# JWT — REQUIRED in production (app will refuse to start without it)
JWT_SECRET=your-super-secret-jwt-key-change-this
# Token lifetime (e.g. 24h, 7d). Optional, defaults to 24h.
JWT_EXPIRES_IN=24h

# App
PORT=3000
NODE_ENV=production

# CORS (comma-separated origins)
CORS_ORIGIN=https://your-frontend-domain.com

# Storage — object storage is always REMOTE; there is NO local-disk provider.
# STORAGE_TYPE: vercel-blob (default) | azure
STORAGE_TYPE=vercel-blob
# Vercel Blob (default): pull the token from the linked project with
#   `vercel link && vercel env pull` (it lands as PCS_DEV_BLOB_READ_WRITE_TOKEN),
# or paste it manually. Resolution order: PCS_DEV_BLOB_READ_WRITE_TOKEN ->
# PCS_BLOB_READ_WRITE_TOKEN -> BLOB_READ_WRITE_TOKEN.
# PCS_DEV_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# BLOB_ACCESS=private          # private (default) | public
# Azure (STORAGE_TYPE=azure):
# AZURE_STORAGE_CONNECTION_STRING=...
# AZURE_CONTAINER_NAME=...

# Real-time transport
# Vercel serverless can't host a WebSocket server, so production pushes events
# through Ably (the backend only makes outbound HTTPS publishes). Locally, leave
# ABLY_API_KEY unset to use the in-process Socket.IO server instead.
#   REALTIME_DRIVER: ably | socketio  (optional; defaults to ably when ABLY_API_KEY is set, else socketio)
#   ABLY_API_KEY:    server-side root key from ably.com -> your app -> API Keys (format appId.keyId:secret)
# REALTIME_DRIVER=ably
# ABLY_API_KEY=

# Processing pipeline / queue (import + 3D conversion)
# Driver for BOTH the import pipeline and the GLB conversion queue:
#   - inline (default, no REDIS_URL): work runs in-process in the API. Fine for
#     local dev and any single always-on host, but NOT for a serverless API
#     (the function freezes after responding → the pipeline never finishes).
#   - bullmq (auto when REDIS_URL is set): the API only PRODUCES jobs; a separate
#     long-running worker (npm run worker) consumes them. This is the deployed
#     setup — Vercel API (producer) + Upstash Redis + a Railway worker.
# REDIS_URL=rediss://default:<password>@<name>.upstash.io:6379   # Upstash TLS URL
# CONVERSION_DRIVER=bullmq                                       # optional; implied by REDIS_URL
# IMPORT_QUEUE_NAME=pcs-import          # BullMQ queue name for the import pipeline
# CONVERSION_QUEUE_NAME=pcs-conversion  # BullMQ queue name for GLB conversion
# IMPORT_CONCURRENCY=2                  # worker: parallel import jobs (sized for ~4GB extraction)
# CONVERSION_CONCURRENCY=2              # worker: parallel conversion jobs

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Seeding (non-production only)
# Password assigned to all seeded users. Set this; the default is insecure.
SEED_DEFAULT_PASSWORD=change-me-in-dev
# Allow the destructive POST /api/health/seed endpoint (never set in production).
# ALLOW_SEED_ENDPOINT=false
