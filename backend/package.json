{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "vercel-build": "nest build vercel && npm prune --omit=dev && rm -rf node_modules/opencascade.js node_modules/web-ifc node_modules/assimpjs node_modules/meshoptimizer node_modules/draco3dgltf node_modules/mikktspace node_modules/three node_modules/@types node_modules/@gltf-transform node_modules/@img node_modules/swagger-ui-dist node_modules/@azure node_modules/typescript node_modules/@aws-sdk node_modules/@smithy",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "worker": "node dist/conversion/worker.js",
    "worker:dev": "nest build && node dist/conversion/worker.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:rbac": "node --experimental-strip-types src/rbac/permission-catalog.test.ts",
    "test:library": "node --experimental-strip-types src/library/library-content.test.ts",
    "test:rbac:e2e": "node test/rbac-roles.e2e.mjs",
    "test:library:e2e": "node test/library.e2e.mjs",
    "test:support:e2e": "node test/support-company.e2e.mjs",
    "test:support-tickets": "node --experimental-strip-types src/support/support-workflow.test.ts",
    "test:support-tickets:e2e": "node test/support.e2e.mjs",
    "test:e2e:orders": "node scripts/order-audit-e2e.mjs",
    "test:quality": "node --experimental-strip-types src/quality-data/quality-math.test.ts && node --experimental-strip-types src/quality-ncr/ncr-workflow.test.ts && node --experimental-strip-types src/work-orders/qc-gate.test.ts && node --experimental-strip-types src/spc/spc-math.test.ts",
    "test:costing": "node --experimental-strip-types src/materials/inventory-math.test.ts && node --experimental-strip-types src/projects/material-requirements-math.test.ts && node --experimental-strip-types src/costing/costing-math.test.ts",
    "test:e2e:quality": "node scripts/quality-e2e.mjs",
    "test:e2e:imports": "node scripts/import-monitoring-e2e.mjs",
    "test:e2e:kanban": "node scripts/kanban-e2e.mjs",
    "test:e2e:costing": "node scripts/costing-e2e.mjs",
    "test:e2e:projects": "node scripts/projects-value-e2e.mjs",
    "test:revision": "node --experimental-strip-types src/projects/revision-diff.test.ts",
    "test:package": "node --experimental-strip-types src/projects/package-import-math.test.ts",
    "test:storage": "node --experimental-strip-types src/storage/storage-keys.test.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "node node_modules/@nestjs/cli/bin/nest.js build && node node_modules/typeorm/cli.js migration:generate -d dist/database/typeorm.config.js",
    "migration:run": "node node_modules/@nestjs/cli/bin/nest.js build && node node_modules/typeorm/cli.js migration:run -d dist/database/typeorm.config.js",
    "migration:revert": "node node_modules/@nestjs/cli/bin/nest.js build && node node_modules/typeorm/cli.js migration:revert -d dist/database/typeorm.config.js",
    "migration:create": "node node_modules/typeorm/cli.js migration:create"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@azure/storage-blob": "^12.26.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.1.0",
    "@vercel/blob": "^2.4.0",
    "assimpjs": "^0.0.10",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "draco3dgltf": "^1.5.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "meshoptimizer": "^1.1.1",
    "mikktspace": "^1.1.1",
    "multer": "^2.1.1",
    "opencascade.js": "^2.0.0-beta.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "web-ifc": "^0.0.77"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
