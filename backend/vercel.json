{
  "installCommand": "npm ci --include=dev",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "{dist/**,public/**,node_modules/**}"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
